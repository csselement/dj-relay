{
	auto_https disable_redirects
	servers {
		protocols h1 h2
	}
}

{$DJ_RELAY_DOMAIN:localhost} {
	tls {
		issuer {$CADDY_TLS_ISSUER:acme}
	}

	encode zstd gzip

	@media path /media/*
	handle @media {
		uri strip_prefix /media
		reverse_proxy mediamtx:8889
	}

	handle {
		reverse_proxy app:3000
	}

	header {
		Alt-Svc "clear"
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(self)"
		-Server
	}
}

https://{$DJ_RELAY_DOMAIN:localhost}:9440 {
	tls {
		issuer {$CADDY_TLS_ISSUER:acme}
	}

	reverse_proxy https://192.168.8.206:9440 {
		transport http {
			tls_insecure_skip_verify
		}
	}

	header {
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		-Server
	}
}
